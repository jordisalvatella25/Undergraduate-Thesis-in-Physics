<CompuCell3D Revision="2" Version="4.6.0">
   
   <Metadata>
      
      <!-- Basic properties simulation -->
      <NumberOfProcessors>10</NumberOfProcessors>
      <DebugOutputFrequency>15</DebugOutputFrequency>
      <!-- <NonParallelModule Name="Potts"/> -->
   </Metadata>
   
   <Potts>
      
      <!-- Basic properties of CPM (GGH) algorithm -->
      <Dimensions x="100" y="100" z="100"/>
      <Steps>20000</Steps>
      <Temperature>10.0</Temperature>
      <NeighborOrder>2</NeighborOrder>
      <Boundary_x>Periodic</Boundary_x>
      <Boundary_y>Periodic</Boundary_y>
      <Boundary_z>Periodic</Boundary_z>
   </Potts>
   
   <Plugin Name="CellType">
      
      <!-- Listing all cell types in the simulation -->
      <CellType TypeId="0" TypeName="Medium"/>
      <CellType TypeId="1" TypeName="TCell"/>
      <CellType TypeId="2" TypeName="ActivatedTCell"/>
      <CellType Freeze="" TypeId="3" TypeName="Wall"/>
   </Plugin>
   
   <Plugin Name="Volume"/>
   
   <Plugin Name="Surface"/>
   
   <Plugin Name="CenterOfMass">
      
      <!-- Module tracking center of mass of each cell -->
   </Plugin>
   
   <Plugin Name="NeighborTracker">
      
      <!-- Module tracking neighboring cells of each cell -->
   </Plugin>
   
   <Plugin Name="BoundaryPixelTracker">
   
      <!-- Module tracking boundary pixels of each cell -->
      <NeighborOrder>1</NeighborOrder>
   </Plugin>
   
   <Plugin Name="Contact">
      <!-- Specification of adhesion energies -->
      <Energy Type1="Medium" Type2="Medium">0.0</Energy>
      <Energy Type1="Medium" Type2="TCell">2.5</Energy>
      <Energy Type1="Medium" Type2="ActivatedTCell">2.5</Energy>
      <Energy Type1="Medium" Type2="Wall">0.0</Energy>
      <Energy Type1="TCell" Type2="TCell">5.0</Energy>
      <Energy Type1="TCell" Type2="ActivatedTCell">5.0</Energy>
      <Energy Type1="TCell" Type2="Wall">1.0</Energy>
      <Energy Type1="ActivatedTCell" Type2="ActivatedTCell">5.0</Energy>
      <Energy Type1="ActivatedTCell" Type2="Wall">1.0</Energy>
      <Energy Type1="Wall" Type2="Wall">0.0</Energy>
      <NeighborOrder>2</NeighborOrder>
   </Plugin>
   
</CompuCell3D>
